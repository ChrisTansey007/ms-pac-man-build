{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["description", "risks", "last_updated"],
  "properties": {
    "description": { "type": "string", "minLength": 1 },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "likelihood", "impact", "mitigation", "status", "identified"],
        "properties": {
          "id": { "type": "string", "pattern": "^RISK-[0-9]{3}$" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "likelihood": { "type": "string" },
          "impact": { "type": "string" },
          "mitigation": { "type": "string", "minLength": 1 },
          "status": { "type": "string" },
          "identified": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "last_updated": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
